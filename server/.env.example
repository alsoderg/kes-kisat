# Kopioi tämä tiedostoksi .env ja täytä arvot

# Postgres-yhteys
DATABASE_URL=postgres://kesakisat:salasana@localhost:5432/kesakisat

# JWT-allekirjoitusavain – generoi pitkä satunnainen merkkijono, esim:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=vaihda-tama-pitkaksi-satunnaiseksi

# Palvelimen portti
PORT=3001

# Tuotannossa true (vaatii HTTPS), kehityksessä false
COOKIE_SECURE=false

# Ensimmäisen admin-tilin tiedot (käytetään db:seed-skriptissä)
ADMIN_USERNAME=allu
ADMIN_PASSWORD=vaihda-tama
ADMIN_DISPLAY_NAME=Allu
