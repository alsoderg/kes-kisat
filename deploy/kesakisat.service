[Unit]
Description=Allun Kesakisat
After=network.target postgresql.service

[Service]
Type=simple
User=kesakisat
WorkingDirectory=/opt/kesakisat
EnvironmentFile=/opt/kesakisat/server/.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm run start
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
